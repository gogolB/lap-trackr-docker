# Database
POSTGRES_USER=laptrackr
POSTGRES_PASSWORD=changeme
POSTGRES_DB=laptrackr
DATABASE_URL=postgresql+asyncpg://laptrackr:changeme@db:5432/laptrackr

# Auth
JWT_SECRET=change-this-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Camera serials (find via ZED Explorer or `camera/list` endpoint)
ZED_SERIAL_ON_AXIS=
ZED_SERIAL_OFF_AXIS=

# Paths
DATA_DIR=/data

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000

# Camera service
CAMERA_HOST=0.0.0.0
CAMERA_PORT=8001
