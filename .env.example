# Database
POSTGRES_USER=laptrackr
POSTGRES_PASSWORD=changeme
POSTGRES_DB=laptrackr
DATABASE_URL=postgresql+asyncpg://laptrackr:changeme@db:5432/laptrackr

# Auth
# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=GENERATE_A_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Camera serials (find via ZED Explorer or `camera/list` endpoint)
# Leave blank or set to MOCK-* for local dev without cameras.
ZED_SERIAL_ON_AXIS=
ZED_SERIAL_OFF_AXIS=

# Paths
DATA_DIR=/data
MODELS_DIR=/data/models

# CORS (comma-separated origins, or "*" for all — credentials disabled with "*")
CORS_ORIGINS=*

# Redis
REDIS_URL=redis://redis:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000

# Camera service
CAMERA_HOST=0.0.0.0
CAMERA_PORT=8001

# ChArUco board calibration
CHARUCO_ROWS=14
CHARUCO_COLS=9
CHARUCO_SQUARE_SIZE_MM=20.0
CHARUCO_MARKER_SIZE_MM=15.0
CHARUCO_DICT=DICT_5X5_50
CALIBRATION_DIR=/data/calibration
